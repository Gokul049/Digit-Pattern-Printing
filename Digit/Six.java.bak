// WAJP TO PRINT SIX IN PATTERN

class  Six
{
	public static void main(String[] args) 
	{
		int n = 5;
		
		for(int i=0;i<n;i++)
		{
			for(int j=0;j<n;j++)
			{
				if(j==n/2 || i==n-1 || i+j==n-1-(n/2))
				{
					System.out.print("* ");
				}
				else
				{
					System.out.print("  ");
				}
			}
			System.out.println();
		}
	}
}
